# ============================================================================
# MCP Web Search Tool — environment variables
# Copy this file to `.env` and fill in the values that apply to your setup.
# ============================================================================

# Brave Search API key. Get one at https://api-dashboard.search.brave.com/
# When omitted, the server falls back to the keyless DuckDuckGo provider as
# long as ALLOW_KEYLESS=true (the default).
BRAVE_API_KEY=

# Maximum number of results returned per query (1–50). Default: 10.
MAX_RESULTS=10

# Per-request HTTP timeout in milliseconds (1000–60000). Default: 10000.
REQUEST_TIMEOUT=10000

# Default search provider name (lowercase, e.g. "brave search" or "duckduckgo").
# When omitted, Brave is preferred if BRAVE_API_KEY is set; otherwise DuckDuckGo.
DEFAULT_PROVIDER=

# When false, the server refuses to start without a Brave API key.
# Set to false in environments where DuckDuckGo scraping is not acceptable.
ALLOW_KEYLESS=true

# Cache tuning (in-memory only).
CACHE_MAX_ENTRIES=256
CACHE_TTL_MS=300000        # 5 minutes for search results

FETCH_CACHE_MAX=128
FETCH_CACHE_TTL_MS=600000  # 10 minutes for fetch_url results
FETCH_TIMEOUT_MS=15000
FETCH_MAX_BYTES=2000000    # 2 MB hard cap on URL fetches
